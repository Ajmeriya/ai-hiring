# API Configuration
API_HOST=0.0.0.0
API_PORT=8085
API_RELOAD=True
DEBUG=False
LOG_LEVEL=INFO

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Gemini API Configuration (Optional)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Threshold (Use Gemini if base_score > threshold)
GEMINI_THRESHOLD=0.6

# Microservice URLs
APPLICATION_SERVICE_URL=http://localhost:8083
JOB_SERVICE_URL=http://localhost:8082
